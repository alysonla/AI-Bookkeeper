PORT=3000
NODE_ENV=development
LOG_LEVEL=info

META_VERIFY_TOKEN=replace-with-your-verify-token
META_ACCESS_TOKEN=replace-with-your-meta-access-token
META_PHONE_NUMBER_ID=replace-with-your-phone-number-id
WHATSAPP_SMOKE_TEST=false
WHATSAPP_SMART_REPLIES=false

OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-5.1

GOOGLE_SHEETS_SPREADSHEET_ID=replace-with-your-spreadsheet-id
GOOGLE_SHEETS_RANGE=Transactions!A:M
GOOGLE_SHEETS_CACHE_TTL_MS=60000
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
GOOGLE_SERVICE_ACCOUNT_EMAIL=replace-with-service-account-email
GOOGLE_PRIVATE_KEY="replace-with-private-key"
